# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bacpilot
# For a quick schema-only check without Postgres (no vector search):
# DATABASE_URL=sqlite:///dev.sqlite3

# --- LLM provider (swappable; mock is safe/local and default for tutor commands/API) ---
LLM_PROVIDER=mock                 # mock | anthropic | openai
LLM_MODEL=mock-tutor-v1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Embeddings (must be multilingual: FR / AR / Darja) ---
EMBEDDING_PROVIDER=openai         # openai | mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=32

# --- Reranker (optional but high ROI) ---
RERANK_PROVIDER=cohere            # cohere | llm | none
COHERE_API_KEY=

# --- OCR (only needed for scanned PDFs / math) ---
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# --- Retrieval tuning ---
RETRIEVAL_TOP_K=6
RETRIEVAL_CANDIDATES=30
RETRIEVAL_THRESHOLD=0.35          # below this => weak retrieval => fallback behavior
MIN_RELEVANCE_WEIGHT=0.0          # filter out eras below this weight (0 = keep all)

    "items": [
      {
        "question": "1",
        "text": "f'(x) = 1 - 1/x = (x - 1)/x. Sur ]0, +∞[, x > 0 donc le signe de f'(x) est celui de (x - 1) : f'(x) < 0 sur ]0, 1[ et f'(x) > 0 sur ]1, +∞[.",
        "steps": ["Dériver f", "Mettre f'(x) sous forme (x-1)/x", "Étudier le signe selon x-1"]
      },
      {
        "question": "2",
        "text": "f est décroissante sur ]0, 1[, croissante sur ]1, +∞[, avec un minimum en x = 1 où f(1) = 1.",
        "steps": ["Utiliser le signe de f'", "Identifier le minimum en x=1", "Construire le tableau de variations"]
      },
      {
        "question": "3",
        "text": "En +∞ : f(x) = x - ln(x) → +∞ (croissance comparée). En 0+ : ln(x) → -∞ donc -ln(x) → +∞ et f(x) → +∞.",
        "steps": ["Limite en +∞ par croissance comparée", "Limite en 0+ via ln(x) → -∞"]
      }
    ]
  },
